{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate configuration for git build-workflow pins and release image references",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "baseBranchPatterns": ["$default", "release"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update build-workflow main SHA pins across workflows and schema URLs",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/.*\\.ya?ml$/",
        "/^\\.ci\\/build\\.json$/"
      ],
      "matchStrings": [
        "runlix/build-workflow/\\.github/workflows/[^@\\s]+@(?<currentDigest>[a-f0-9]{40})",
        "ghcr\\.io/runlix/build-workflow-tools:sha-(?<currentDigest>[a-f0-9]{40})",
        "https://raw\\.githubusercontent\\.com/runlix/build-workflow/(?<currentDigest>[a-f0-9]{40})/schema/build-config\\.schema\\.json"
      ],
      "currentValueTemplate": "main",
      "depNameTemplate": "runlix/build-workflow",
      "packageNameTemplate": "https://github.com/runlix/build-workflow",
      "datasourceTemplate": "git-refs"
    },
    {
      "customType": "regex",
      "description": "Update Debian builder refs in release build config and Dockerfiles",
      "managerFilePatterns": [
        "/^\\.ci\\/build\\.json$/",
        "/^linux-(amd64|arm64)\\.Dockerfile$/"
      ],
      "matchStrings": [
        "\"BUILDER_REF\"\\s*:\\s*\"(?<depName>docker\\.io/library/debian):(?<currentValue>[^\"@]+)@(?<currentDigest>sha256:[a-f0-9]{64})\"",
        "ARG BUILDER_REF=\"(?<depName>docker\\.io/library/debian):(?<currentValue>[^\"@]+)@(?<currentDigest>sha256:[a-f0-9]{64})\""
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update Distroless runtime refs in release build config and Dockerfiles",
      "managerFilePatterns": [
        "/^\\.ci\\/build\\.json$/",
        "/^linux-(amd64|arm64)\\.Dockerfile$/"
      ],
      "matchStrings": [
        "\"BASE_REF\"\\s*:\\s*\"(?<depName>ghcr\\.io/runlix/distroless-runtime-v2-canary):(?<currentValue>[^\"@]+)@(?<currentDigest>sha256:[a-f0-9]{64})\"",
        "ARG BASE_REF=\"(?<depName>ghcr\\.io/runlix/distroless-runtime-v2-canary):(?<currentValue>[^\"@]+)@(?<currentDigest>sha256:[a-f0-9]{64})\""
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Manage build-workflow reusable workflow refs atomically via regex",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["runlix/build-workflow"],
      "enabled": false
    },
    {
      "description": "Group build-workflow main SHA updates",
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["git-refs"],
      "matchDepNames": ["runlix/build-workflow"],
      "groupName": "Build Workflow pins",
      "commitMessageTopic": "build-workflow pin",
      "rebaseWhen": "behind-base-branch"
    },
    {
      "description": "Group Debian builder updates",
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["docker.io/library/debian"],
      "groupName": "Debian builder",
      "commitMessageTopic": "Debian builder image"
    },
    {
      "description": "Group Distroless runtime updates",
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/runlix/distroless-runtime-v2-canary"],
      "groupName": "Distroless runtime",
      "commitMessageTopic": "Distroless runtime base image"
    },
    {
      "description": "Group Go module updates",
      "matchManagers": ["gomod"],
      "groupName": "Go modules"
    },
    {
      "description": "Auto-merge digest-only Docker ref updates",
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["docker"],
      "matchFileNames": ["**/.ci/build.json", "linux-*.Dockerfile"],
      "matchUpdateTypes": ["digest"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    }
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "🔄 Dependency Updates Dashboard",
  "dependencyDashboardApproval": false,
  "labels": [
    "dependencies",
    "docker"
  ],
  "timezone": "UTC",
  "prConcurrentLimit": 3,
  "prHourlyLimit": 1
}
